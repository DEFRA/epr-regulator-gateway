{
  "DetailedErrors": true,
  "AllowedHosts": "*",
  "UserService": {
    "BaseUrl": "https://localhost:5000/",
    "Scope": "",
    "TimeoutSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:o} [{Level:u4}] ({Application}/{MachineName}/{ThreadId}/{SourceContext}.{Method}) {Message}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Acl": {
    "Clients": {
      "Developer": {
        "Type": "ApiKey",
        "Secret": "developer-rpd",
        "Scopes": [
          "read",
          "write"
        ]
      },
      "IntegrationTest": {
        "Type": "OAuth",
        "Scopes": [
          "read",
          "write"
        ]
      }
    }
  }
}
